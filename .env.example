# ===========================================
# Servidor
# ===========================================
# Porta em que o Django sobe. Use: python run.py (lê HOST_PORT automaticamente)
HOST_PORT=3000

# ===========================================
# Banco de Dados (use DATABASE_URL ou DB_*)
# ===========================================
# DATABASE_URL=postgresql://user:password@host:port/dbname?schema=public
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=sua_senha_aqui
DB_NAME=truckflow
DB_PROVIDER=postgres

# ===========================================
# FIPE integration
# ===========================================
FIPE_BASE_URL=https://fipe.parallelum.com.br/api/v2
FIPE_TRUCK_VEHICLE_TYPE=trucks
# Template (opcional) para montar URL da aplicação/integração
# Exemplo: app.fipe/{placa}/modelo/{modelo}
FIPE_APP_URL_TEMPLATE=app.fipe/{placa}/modelo/{modelo}

# ===========================================
# Autenticação JWT
# ===========================================
JWT_SECRET=sua-chave-secreta-muito-segura-aqui
JWT_EXPIRES_IN=7d

# ===========================================
# Redis
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=6379

# ===========================================
# Armazenamento
# ===========================================
UPLOAD_PATH=./uploads
STORAGE_PATH=./storage

# ===========================================
# Docker - Superusuário (criado automaticamente no first run)
# ===========================================
# SUPERUSER_USERNAME=admin
# SUPERUSER_EMAIL=admin@truckflow.com
# SUPERUSER_PASSWORD=admin123
